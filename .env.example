# ============================================
# Raji Finance — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================

# --- App ---
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:9000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://raji:raji_dev@localhost:5432/raji_finance?schema=public

# --- JWT / Autenticação ---
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_SECURE_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=30d

# --- Stripe (Pagamentos / Assinatura Premium) ---
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_PREMIUM_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_PREMIUM_YEARLY=price_CHANGE_ME

# --- Push Notifications (Web Push / FCM) ---
VAPID_PUBLIC_KEY=CHANGE_ME
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_SUBJECT=mailto:contato@rajifinance.com

# --- SMTP (E-mail) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM="Raji Finance <noreply@rajifinance.com>"

# --- Frontend (Quasar) ---
API_URL=http://localhost:3000/api/v1
