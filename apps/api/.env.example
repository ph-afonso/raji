# ===========================================
# Raji Finance API — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Database (Prisma)
DATABASE_URL="file:./dev.db"

# JWT Secrets (REQUIRED — no fallback, app will crash without these)
JWT_SECRET="generate-a-strong-random-secret-here"
JWT_REFRESH_SECRET="generate-a-different-strong-random-secret-here"

# Server
PORT=3000

# CORS — Frontend origin (comma-separated for multiple)
CORS_ORIGIN="http://localhost:9000"

# Node environment
NODE_ENV="development"
