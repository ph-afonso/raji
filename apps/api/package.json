{
  "name": "@raji/api",
  "version": "0.1.0",
  "private": true,
  "description": "Raji Finance — API Backend (NestJS)",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
